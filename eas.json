{
  "cli": {
    "version": ">= 18.13.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.goat-jobhunter.click/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.goat-jobhunter.click/ws"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.goat-jobhunter.click/api/v1",
        "EXPO_PUBLIC_SOCKET_URL": "https://api.goat-jobhunter.click/ws"
      }
    }
  },
  "submit": {
    "production": {}
  }
}

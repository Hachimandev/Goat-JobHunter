{
  "expo": {
    "name": "Goat-JobHunter-Mobile",
    "slug": "goat-jobhunter-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "goatjobhunter",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.goatjobhuntermobile",
      "config": {
        "googleMapsApiKey": "YOUR_IOS_GOOGLE_MAPS_API_KEY"
      },
      "associatedDomains": [
        "applinks:goat-jobhunter.click",
        "applinks:www.goat-jobhunter.click"
      ],
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["goatjobhunter"]
      }
    },
    "android": {
      "package": "com.anonymous.goatjobhuntermobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "goat-jobhunter.click",
              "pathPrefix": "/invite"
            },
            {
              "scheme": "https",
              "host": "www.goat-jobhunter.click",
              "pathPrefix": "/invite"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
